# Copy to .env.local for local dev.
# For Vercel: set these in Project → Settings → Environment Variables.

# Public site URL (used for sitemap, robots, OG tags). Set this in your hosting env.
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────
# LLM enrichment (REQUIRED for Pro AI roasts)
# ─────────────────────────────────────────────────────────────
# MiniMax M3 (OpenAI Chat Completions compatible)
LLM_BASE_URL=https://api.minimax.io

# Your MiniMax M3 API key. REQUIRED for Pro tier LLM enrichment.
LLM_API_KEY=sk-cp-your-key-here

LLM_MODEL=MiniMax-M3
LLM_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Pro plan — shared API key for paid subscribers
# Set any secret string. Pro users pass it as x-api-key header.
# ─────────────────────────────────────────────────────────────
PRO_API_KEY=ch@nge-me-t0-s0m3th1ng-s3cur3

# ─────────────────────────────────────────────────────────────
# Screenshots (OPTIONAL — text-only without this)
# ─────────────────────────────────────────────────────────────
# On Vercel serverless, use Browserless.io (free tier: 1000/mo)
# BROWSERLESS_URL=https://production-sfo.browserless.io
# BROWSERLESS_TOKEN=your-browserless-token

# Or disable screenshots entirely:
DISABLE_SCREENSHOTS=true

# ─────────────────────────────────────────────────────────────
# PayPal payments — https://developer.paypal.com/dashboard
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_SANDBOX=true

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
# Optional rate limit override for free tier. Format: "<requests>/<seconds>".
# Default: 3/86400 (3 per day). Set higher for dev.
RATE_LIMIT=3/86400
