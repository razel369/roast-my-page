# Copy to .env.local for local dev.
# For Vercel: set these in Project → Settings → Environment Variables.

# Public site URL (used for sitemap, robots, OG tags, Polar redirect).
NEXT_PUBLIC_SITE_URL=https://your-domain.com

# ─────────────────────────────────────────────────────────────
# LLM enrichment (REQUIRED for Pro AI roasts)
# ─────────────────────────────────────────────────────────────
# Default: Google Gemini 2.5 Flash (OpenAI-compatible).
# Pricing: $0.15/M input, $0.60/M output. Free tier OK for low volume.
# Get a key: https://aistudio.google.com/app/apikey
LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# Your Google AI Studio key. REQUIRED for Pro tier LLM enrichment.
LLM_API_KEY=AIzaSy_your-key-here

# Gemini 2.5 Flash (newest, recommended). Alternatives:
#   gemini-2.0-flash      (slightly older, very stable)
#   gemini-1.5-flash      (cheapest, very stable)
# Or any OpenAI-compatible provider (Anthropic via proxy, OpenAI, DeepSeek, etc).
LLM_MODEL=gemini-2.5-flash
LLM_ENABLED=true

# ─────────────────────────────────────────────────────────────
# Pro plan — Polar.sh subscription (recommended 2026)
# https://polar.sh — accepts Israeli individuals, no business needed.
# ─────────────────────────────────────────────────────────────
# Personal Access Token from Polar.sh → Settings → Developers
POLAR_ACCESS_TOKEN=polar_pat_xxxxxxxxxxxxxx

# Organization ID (visible in Polar dashboard URL)
POLAR_ORGANIZATION_ID=org_xxxxxxxxxxxxxx

# Product IDs from your Polar Products dashboard (Pro $19/mo or $190/yr, Team $79/mo)
POLAR_PRODUCT_PRO_ID=prod_xxxxxxxxxxxxxx
POLAR_PRODUCT_PRO_YEARLY_ID=prod_xxxxxxxxxxxxxx
POLAR_PRODUCT_TEAM_ID=prod_xxxxxxxxxxxxxx

# Webhook secret — Polar generates this when you add a webhook endpoint.
# Vercel webhook URL: https://your-domain.com/api/webhook/polar
POLAR_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxx

# Set true for Polar sandbox (testing). Production = false.
POLAR_SANDBOX=false

# ─────────────────────────────────────────────────────────────
# Pro token persistence (OPTIONAL but RECOMMENDED for multi-instance)
# Without these, tokens live in process memory — lost on every Vercel cold start.
# ─────────────────────────────────────────────────────────────
# Free tier at https://upstash.com — 10K commands/day
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# ─────────────────────────────────────────────────────────────
# Screenshots (OPTIONAL — text-only without this)
# ─────────────────────────────────────────────────────────────
# On Vercel serverless, use Browserless.io (free tier: 1000/mo)
# BROWSERLESS_URL=https://production-sfo.browserless.io
# BROWSERLESS_TOKEN=your-browserless-token

# Or disable screenshots entirely:
DISABLE_SCREENSHOTS=true

# ─────────────────────────────────────────────────────────────
# Misc
# ─────────────────────────────────────────────────────────────
# Optional rate limit override for free tier. Format: "<requests>/<seconds>".
# Default: 3/86400 (3 per day). Set higher for dev.
RATE_LIMIT=3/86400
